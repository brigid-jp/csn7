local ai_novelist_url = "https://api.tringpt.com/api"

local boundary_table = {}

local a, b = ("09"):byte(1, 2)
for byte = a, b do
  boundary_table[#boundary_table + 1] = string.char(byte)
end

local a, b = ("AZ"):byte(1, 2)
for byte = a, b do
  boundary_table[#boundary_table + 1] = string.char(byte)
end

local a, b = ("az"):byte(1, 2)
for byte = a, b do
  boundary_table[#boundary_table + 1] = string.char(byte)
end

