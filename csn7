-- https://www.iana.org/assignments/media-types/media-types.xhtml
local media_types = {
  json = "application/json";
  urlencoded = "application/x-www-form-urlencoded";
  multipart = "multipart/form-data";
  octet_stream = "application/octet-stream";
  jpg = "image/jpeg";
  jpeg = "image/jpeg";
  png = "image/png";
  webp = "image/webp";
}

